classDiagram
    User "1" -- "*" Booking : makes
    User "1" -- "*" Reservation : makes
    User "1" -- "*" Payment : makes
    User "1" -- "*" HousekeepingLog : assigned to
    User "1" -- "*" Notification : receives
    User "1" -- "*" Review : writes
    User "1" -- "*" PoolReservation : books
    User "1" -- "*" Pool : updates

    RoomType "1" -- "*" Room : categorizes
    RoomType "1" -- "*" Review : receives
    RoomType "*" -- "*" Amenity : includes

    Room "1" -- "*" Booking : has
    Room "1" -- "*" Reservation : has
    Room "1" -- "*" HousekeepingLog : has
    Room "1" -- "*" PoolReservation : links to

    Booking "1" -- "0..1" Reservation : links to
    Booking "1" -- "0..1" Payment : has
    Payment "1" -- "1" Booking : pays for

    Pool "1" -- "*" PoolReservation : has
    PoolSlot "1" -- "*" PoolReservation : reserved in

    class User {
        +ObjectId _id
        +string fullName
        +string email
        +string phone
        +string passwordHash
        +string profileImage
        +string role
        +string status
        +string resetPasswordCode
        +date resetPasswordExpires
        +ObjectId[] tasksAssigned
        +date createdAt
        +date updatedAt
        +register()
        +login()
        +forgotPassword()
        +resetPassword()
        +getProfile()
        +updateProfile()
    }

    class RoomType {
        +ObjectId _id
        +ObjectId[] amenities
        +string typeName
        +string description
        +int basePrice
        +int maxAdults
        +int maxChildren
        +int maxGuests
        +string bedType
        +int sizeSqm
        +string[] images
        +int rating
        +int numReviews
        +int discount
        +boolean isActive
        +boolean isFeatured
        +date createdAt
        +date updatedAt
        +createRoomType()
        +getRoomTypes()
        +getRoomTypeById()
        +updateRoomType()
        +deleteRoomType()
    }

    class Room {
        +ObjectId _id
        +ObjectId roomTypeId
        +string roomNumber
        +int floor
        +string status
        +string notes
        +date createdAt
        +date updatedAt
        +createRoom()
        +getAllRooms()
        +getRoomById()
        +updateRoom()
        +deleteRoom()
        +updateStatus()
    }

    class Amenity {
        +ObjectId _id
        +string name
        +string icon
        +boolean isActive
        +date createdAt
        +date updatedAt
        +createAmenity()
        +getAmenities()
        +updateAmenity()
        +deleteAmenity()
    }

    class Booking {
        +ObjectId _id
        +ObjectId reservationId
        +ObjectId guestId
        +ObjectId paymentId
        +string bookingCode
        +date checkInDate
        +date checkOutDate
        +int adultsCount
        +int childrenCount
        +string status
        +int subtotalAmount
        +int taxAmount
        +int totalPrice
        +date createdAt
        +date updatedAt
        +createBooking()
        +getAllBookings()
        +getBookingById()
        +updateBooking()
        +cancelBooking()
        +checkIn()
        +checkOut()
    }

    class Reservation {
        +ObjectId _id
        +ObjectId guestId
        +string reservationCode
        +date checkInDate
        +date checkOutDate
        +int adultsCount
        +int childrenCount
        +int roomsCount
        +int subtotalAmount
        +int taxAmount
        +int totalAmount
        +string status
        +date expiresAt
        +date createdAt
        +date updatedAt
        +createReservation()
        +getAllReservations()
        +getReservationById()
        +updateReservation()
        +cancelReservation()
        +confirmReservation()
    }

    class Payment {
        +ObjectId _id
        +ObjectId bookingId
        +ObjectId guestId
        +int amount
        +string currency
        +string paymentMethod
        +string status
        +string transactionId
        +date createdAt
        +date updatedAt
        +processPayment()
        +getPaymentDetails()
        +refundPayment()
    }

    class HousekeepingLog {
        +ObjectId _id
        +ObjectId roomId
        +ObjectId staffId
        +string status
        +string task
        +string note
        +date createdAt
        +date updatedAt
        +createTask()
        +getAllTasks()
        +getMyTasks()
        +updateTaskStatus()
        +deleteTask()
    }

    class Notification {
        +ObjectId _id
        +ObjectId recipient
        +string message
        +string type
        +boolean isRead
        +string link
        +date createdAt
        +date updatedAt
        +getNotifications()
        +markAsRead()
        +deleteNotification()
    }

    class Review {
        +ObjectId _id
        +ObjectId userId
        +ObjectId roomTypeId
        +int rating
        +string comment
        +date createdAt
        +date updatedAt
        +addReview()
        +getRoomTypeReviews()
        +deleteReview()
    }

    class Pool {
        +ObjectId _id
        +ObjectId updatedBy
        +string name
        +string status
        +int currentOccupancy
        +int maxCapacity
        +int temperature
        +string openingTime
        +string closingTime
        +string notes
        +date createdAt
        +date updatedAt
        +getPoolStatus()
        +updatePoolStatus()
    }

    class PoolSlot {
        +ObjectId _id
        +string startTime
        +string endTime
        +int maxPeople
        +int currentReserved
        +string date
        +date createdAt
        +date updatedAt
        +getPoolSlots()
    }

    class PoolReservation {
        +ObjectId _id
        +ObjectId userId
        +ObjectId roomId
        +ObjectId slotId
        +string status
        +date createdAt
        +date updatedAt
        +bookPoolSlot()
        +getMyPoolReservations()
        +cancelPoolReservation()
    }
